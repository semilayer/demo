# SemiLayer Live Demo — public config (committed on purpose).
#
# Publishable keys (`pk_…`) are read-only and scoped to a single environment
# server-side via the lens's `rules` config. They are designed to ship to
# the browser the way Stripe pk_live_… or Mapbox tokens do — see README.

NEXT_PUBLIC_API_BASE=https://api.semilayer.com
NEXT_PUBLIC_ORG=demo
NEXT_PUBLIC_PROJECT=public
NEXT_PUBLIC_ENV=demo-env
NEXT_PUBLIC_LENS=food_products

# Publishable key for the demo env. Read-only, scoped to one environment.
# See README → "About the URL shape" for why this is safe to commit.
NEXT_PUBLIC_API_KEY=pk_demo-env_JJqnkAEaL0c6Z6T_b27drjtu_8hkm3lf
